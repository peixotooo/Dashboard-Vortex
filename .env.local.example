# === Required to run the dashboard ===
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron auth
CRON_SECRET=

# === Email Templates Generator ===
# HMAC secret for signing countdown PNG URLs.
# Generate with: openssl rand -hex 32
EMAIL_COUNTDOWN_SECRET=

# Public app URL used as base when building absolute URLs in emails.
# Production should be the dashboard's public domain. Falls back to APP_URL or
# https://app.bulking.com.br if neither is set.
NEXT_PUBLIC_APP_URL=https://app.bulking.com.br

# === Google Ads (página /google-ads) ===
# Passo a passo completo: docs/google-ads-setup.md
# 1) Developer token: API Center de uma conta GERENCIADORA (MCC) — precisa de
#    "Basic Access" para acessar contas reais (token "test" só vê contas de teste).
GOOGLE_ADS_DEVELOPER_TOKEN=
# 2) OAuth client tipo "Desktop app" (Google Cloud Console > Credentials).
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# 3) Refresh token: gere com `npx tsx scripts/google-ads-auth.ts`
#    (publique a tela de consentimento — modo "Testing" expira em 7 dias).
GOOGLE_ADS_REFRESH_TOKEN=
# 4) ID da conta a consultar (só dígitos, sem hífens). Descubra com o script acima.
GOOGLE_ADS_CUSTOMER_ID=
# 5) Só para contas sob MCC: ID da conta gerenciadora (só dígitos). Deixe vazio
#    para conta direta.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Opcional: versão da API (default v24). Bump aqui quando o Google descontinuar.
GOOGLE_ADS_API_VERSION=v24
